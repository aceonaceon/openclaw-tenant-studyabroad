# Caddy reverse proxy configuration
# Each tenant gets a subdomain with WebChat access
# Admin-only paths are blocked — admin uses localhost directly via SSH tunnel
# Caddy handles HTTPS automatically via Let's Encrypt

# Tenant: client-a
client-a.yourlobster.com {
  # Block admin-only paths (Gateway Control UI settings, API endpoints)
  handle /api/settings* {
    respond "403 Forbidden" 403
  }
  handle /api/admin* {
    respond "403 Forbidden" 403
  }

  # Allow everything else (WebChat, static assets, WebSocket, etc.)
  handle {
    reverse_proxy 127.0.0.1:21001
  }
}

# Tenant: client-b
client-b.yourlobster.com {
  handle /api/settings* {
    respond "403 Forbidden" 403
  }
  handle /api/admin* {
    respond "403 Forbidden" 403
  }

  handle {
    reverse_proxy 127.0.0.1:21001
  }
}

# Admin access: use SSH tunnel or VPN to reach localhost directly
# ssh -L 21001:127.0.0.1:21001 your-vps
# Then open http://localhost:21001 for full Gateway Control UI
