# Caddy reverse proxy configuration for OpenClaw multi-tenant
#
# Authentication: Caddy handles basic_auth, OpenClaw uses trusted-proxy auth
# Each tenant's Caddyfile is auto-generated by new-tenant.sh
# Import them all from your main /etc/caddy/Caddyfile like this:
#
#   import /path/to/tenants/*/Caddyfile
#
# Or import individually:
#
#   import /path/to/tenants/client-a/Caddyfile
#   import /path/to/tenants/client-b/Caddyfile
#
# After adding/changing imports, reload Caddy:
#   sudo systemctl reload caddy

# Example tenant (auto-generated by new-tenant.sh)
client-a.yourlobster.com {
  basic_auth {
    client-a $2a$14$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  }

  @blocked path /api/settings /api/settings/* /api/admin /api/admin/*
  respond @blocked "403 Forbidden" 403

  reverse_proxy 127.0.0.1:21001 {
    header_up X-Forwarded-User {http.auth.user.id}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
  }
}

# IMPORTANT: OpenClaw port must bind to 127.0.0.1 only (not 0.0.0.0)
# This prevents users from bypassing Caddy and sending fake X-Forwarded-User
# In compose.yml: "127.0.0.1:21001:18789" (NOT "21001:18789")

# Admin access: use SSH tunnel to reach localhost directly
# ssh -L 21001:127.0.0.1:21001 your-vps
# Then open http://localhost:21001 for full Gateway Control UI
