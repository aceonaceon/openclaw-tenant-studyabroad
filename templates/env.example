# Tenant environment variables
TENANT_NAME=client-example
PORT=21001
DOMAIN=example.yourlobster.com

# Minimax API Key (each tenant should have their own key for usage tracking)
MINIMAX_API_KEY=

# Gateway token for WebChat authentication (auto-generated by new-tenant.sh)
OPENCLAW_GATEWAY_TOKEN=

# Optional: External channel tokens (add as needed)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# LINE_CHANNEL_ACCESS_TOKEN=
